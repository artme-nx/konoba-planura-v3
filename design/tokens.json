{
  "$schema": "https://design-tokens.org/schema.json",
  "$concept": "KONOBA/OS — a Dalmatian tavern's real story told through the visual grammar of a SaaS product landing page. Warm sand + white product-card surfaces, terracotta CTA, deep Adriatic-teal secondary, ink-navy dark sections. Geist Sans/Mono throughout for the clean 'product' voice; radius stays soft and generous (never editorial-sharp) to sell the tech-landing wink.",
  "primitive": {
    "color": {
      "white": { "$value": "#FFFFFF", "$type": "color" },
      "sand": {
        "50": { "$value": "#FCFAF5", "$type": "color" },
        "100": { "$value": "#F6EFE2", "$type": "color" },
        "200": { "$value": "#EBE0CB", "$type": "color" },
        "300": { "$value": "#D8C9A8", "$type": "color" }
      },
      "stone": {
        "500": { "$value": "#786F5F", "$type": "color" },
        "700": { "$value": "#4A4438", "$type": "color" },
        "900": { "$value": "#241F16", "$type": "color" }
      },
      "ink": {
        "950": { "$value": "#12211D", "$type": "color" },
        "900": { "$value": "#1A302A", "$type": "color" },
        "800": { "$value": "#26443B", "$type": "color" }
      },
      "terracotta": {
        "500": { "$value": "#D9642E", "$type": "color" },
        "600": { "$value": "#BB4E1E", "$type": "color" },
        "700": { "$value": "#8F3A16", "$type": "color" },
        "100": { "$value": "#FBE6D8", "$type": "color" }
      },
      "teal": {
        "500": { "$value": "#1F6672", "$type": "color" },
        "600": { "$value": "#17505A", "$type": "color" },
        "700": { "$value": "#123E46", "$type": "color" },
        "100": { "$value": "#DCEAEA", "$type": "color" }
      },
      "gold": {
        "500": { "$value": "#DE9F3B", "$type": "color" }
      }
    },
    "font": {
      "display": { "$value": "var(--font-geist-sans), 'Geist', system-ui, sans-serif", "$type": "fontFamily" },
      "sans": { "$value": "var(--font-geist-sans), system-ui, sans-serif", "$type": "fontFamily" },
      "mono": { "$value": "var(--font-geist-mono), 'SF Mono', monospace", "$type": "fontFamily" }
    },
    "motion": {
      "duration": {
        "micro": { "$value": "160ms", "$type": "duration" },
        "base": { "$value": "280ms", "$type": "duration" },
        "reveal": { "$value": "700ms", "$type": "duration" }
      },
      "ease": {
        "out-expo": { "$value": "cubic-bezier(0.16, 1, 0.3, 1)", "$type": "cubicBezier" },
        "out-quad": { "$value": "cubic-bezier(0.25, 0.46, 0.45, 0.94)", "$type": "cubicBezier" }
      }
    },
    "radius": {
      "sm": { "$value": "0.5rem", "$type": "dimension" },
      "md": { "$value": "0.85rem", "$type": "dimension" },
      "lg": { "$value": "1.25rem", "$type": "dimension" },
      "xl": { "$value": "1.75rem", "$type": "dimension" },
      "full": { "$value": "9999px", "$type": "dimension" }
    },
    "shadow": {
      "sm": { "$value": "0 1px 2px rgba(36, 31, 22, 0.06)", "$type": "shadow" },
      "md": { "$value": "0 8px 24px -8px rgba(36, 31, 22, 0.16)", "$type": "shadow" },
      "lg": { "$value": "0 24px 60px -16px rgba(18, 33, 29, 0.22)", "$type": "shadow" }
    }
  },
  "semantic": {
    "background": { "$value": "{primitive.color.sand.50}", "$type": "color" },
    "foreground": { "$value": "{primitive.color.stone.900}", "$type": "color" },
    "card": { "$value": "{primitive.color.white}", "$type": "color" },
    "card-foreground": { "$value": "{primitive.color.stone.900}", "$type": "color" },
    "muted": { "$value": "{primitive.color.sand.100}", "$type": "color" },
    "muted-foreground": { "$value": "{primitive.color.stone.500}", "$type": "color" },
    "border": { "$value": "{primitive.color.sand.200}", "$type": "color" },
    "primary": { "$value": "{primitive.color.terracotta.500}", "$type": "color" },
    "primary-foreground": { "$value": "{primitive.color.white}", "$type": "color" },
    "primary-hover": { "$value": "{primitive.color.terracotta.600}", "$type": "color" },
    "secondary": { "$value": "{primitive.color.teal.600}", "$type": "color" },
    "secondary-foreground": { "$value": "{primitive.color.white}", "$type": "color" },
    "accent": { "$value": "{primitive.color.terracotta.100}", "$type": "color" },
    "accent-foreground": { "$value": "{primitive.color.terracotta.700}", "$type": "color" },
    "ring": { "$value": "{primitive.color.terracotta.500}", "$type": "color" },
    "radius": { "$value": "{primitive.radius.lg}", "$type": "dimension" },
    "ink": { "$value": "{primitive.color.ink.950}", "$type": "color" },
    "ink-foreground": { "$value": "{primitive.color.sand.50}", "$type": "color" },
    "ink-muted": { "$value": "{primitive.color.ink.800}", "$type": "color" },
    "gold": { "$value": "{primitive.color.gold.500}", "$type": "color" },
    "type-display": { "$value": "{primitive.font.display}", "$type": "fontFamily" },
    "type-body": { "$value": "{primitive.font.sans}", "$type": "fontFamily" },
    "type-mono": { "$value": "{primitive.font.mono}", "$type": "fontFamily" },
    "ease-out": { "$value": "{primitive.motion.ease.out-expo}", "$type": "cubicBezier" },
    "ease-standard": { "$value": "{primitive.motion.ease.out-quad}", "$type": "cubicBezier" },
    "duration-micro": { "$value": "{primitive.motion.duration.micro}", "$type": "duration" },
    "duration-base": { "$value": "{primitive.motion.duration.base}", "$type": "duration" },
    "duration-reveal": { "$value": "{primitive.motion.duration.reveal}", "$type": "duration" },
    "shadow-sm": { "$value": "{primitive.shadow.sm}", "$type": "shadow" },
    "shadow-md": { "$value": "{primitive.shadow.md}", "$type": "shadow" },
    "shadow-lg": { "$value": "{primitive.shadow.lg}", "$type": "shadow" }
  },
  "component": {
    "badge": {
      "bg": { "$value": "{primitive.color.terracotta.100}", "$type": "color" },
      "fg": { "$value": "{primitive.color.terracotta.700}", "$type": "color" }
    },
    "button": {
      "primary-bg": { "$value": "{primitive.color.terracotta.500}", "$type": "color" },
      "primary-fg": { "$value": "{primitive.color.white}", "$type": "color" },
      "primary-hover-bg": { "$value": "{primitive.color.terracotta.600}", "$type": "color" },
      "ghost-border": { "$value": "{primitive.color.sand.300}", "$type": "color" },
      "ghost-fg": { "$value": "{primitive.color.stone.900}", "$type": "color" },
      "ghost-hover-bg": { "$value": "{primitive.color.sand.100}", "$type": "color" }
    },
    "feature-card": {
      "bg": { "$value": "{primitive.color.white}", "$type": "color" },
      "border": { "$value": "{primitive.color.sand.200}", "$type": "color" },
      "icon-bg": { "$value": "{primitive.color.teal.100}", "$type": "color" },
      "icon-fg": { "$value": "{primitive.color.teal.600}", "$type": "color" },
      "radius": { "$value": "{primitive.radius.lg}", "$type": "dimension" },
      "shadow-hover": { "$value": "{primitive.shadow.md}", "$type": "shadow" }
    },
    "step": {
      "badge-bg": { "$value": "{primitive.color.ink.950}", "$type": "color" },
      "badge-fg": { "$value": "{primitive.color.sand.50}", "$type": "color" },
      "connector": { "$value": "{primitive.color.sand.300}", "$type": "color" }
    },
    "testimonial-card": {
      "bg": { "$value": "{primitive.color.white}", "$type": "color" },
      "border": { "$value": "{primitive.color.sand.200}", "$type": "color" },
      "quote-mark": { "$value": "{primitive.color.terracotta.500}", "$type": "color" },
      "star": { "$value": "{primitive.color.gold.500}", "$type": "color" }
    },
    "hero": {
      "eyebrow-bg": { "$value": "{primitive.color.white}", "$type": "color" },
      "eyebrow-border": { "$value": "{primitive.color.sand.300}", "$type": "color" },
      "title-size": { "$value": "clamp(2.75rem, 6.4vw, 5.25rem)", "$type": "dimension" },
      "title-leading": { "$value": "1.02", "$type": "number" },
      "glow": {
        "$value": "radial-gradient(ellipse 70% 50% at 50% 0%, rgba(217, 100, 46, 0.14), transparent 60%)",
        "$type": "gradient"
      }
    }
  }
}
